{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/babussalam run build",
  "outputDirectory": "artifacts/babussalam/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
    "runtime": "vercel-node@latest"
    
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
