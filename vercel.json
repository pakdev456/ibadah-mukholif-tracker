{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/babussalam/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    },
    {
      "src": "artifacts/api-server/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "artifacts/api-server/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "artifacts/babussalam/dist/public/index.html"
    }
  ]
}